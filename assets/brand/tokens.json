{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "brand": "Gaffr",
  "version": "1.0.0",
  "color": {
    "pitch": {
      "value": "#1A5C42",
      "rgb": [26, 92, 66],
      "cmyk": [72, 0, 28, 64],
      "role": "Primary brand colour. Backgrounds, large surfaces."
    },
    "matchday": {
      "value": "#2EBE6B",
      "rgb": [46, 190, 107],
      "cmyk": [76, 0, 44, 25],
      "role": "Action / affirmation. CTAs, success states, the centre-spot dot."
    },
    "chalk": {
      "value": "#F2F4EE",
      "rgb": [242, 244, 238],
      "cmyk": [2, 0, 2, 4],
      "role": "Primary text on dark, light surface backgrounds."
    },
    "pitch-deep": {
      "value": "#0E3A29",
      "rgb": [14, 58, 41],
      "role": "Dark mode backgrounds, app icon background."
    },
    "trophy-amber": {
      "value": "#F5B544",
      "rgb": [245, 181, 68],
      "role": "Accent only. Highlights, rewards, coming-soon states. Never primary."
    },
    "slate": {
      "value": "#1A1F1C",
      "rgb": [26, 31, 28],
      "role": "Body text on light backgrounds."
    }
  },
  "proportion": {
    "pitch": "60%",
    "chalk": "25%",
    "matchday": "10%",
    "trophy-amber": "5%"
  },
  "typography": {
    "family": "Inter",
    "fallback": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "weights": {
      "regular": 400,
      "medium": 500,
      "bold": 700,
      "extrabold": 800
    },
    "scale": {
      "display": { "size": 32, "lineHeight": 36 },
      "h1":      { "size": 24, "lineHeight": 28 },
      "h2":      { "size": 18, "lineHeight": 22 },
      "body":    { "size": 15, "lineHeight": 22 },
      "caption": { "size": 12, "lineHeight": 16 }
    },
    "numerals": "Use Inter tabular-nums for minutes-played and scores."
  }
}
